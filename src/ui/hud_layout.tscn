[gd_scene format=3]

; Shell scene: only the minimap SubViewport subtree lives here (its render setup
; is fiddly and worth keeping as a scene). hud.gd re-parents MinimapAspect into
; the code-built left-rail "ORBIT MAP" panel and builds every other region in
; code from Palette/UiTheme tokens (TD-1: one colour source).

[node name="HudLayout" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

[node name="MinimapAspect" type="AspectRatioContainer" parent="."]
custom_minimum_size = Vector2(280, 207)
layout_mode = 2
mouse_filter = 2
ratio = 1.35

[node name="MinimapRoot" type="Control" parent="MinimapAspect"]
layout_mode = 2
mouse_filter = 2

[node name="Back" type="ColorRect" parent="MinimapAspect/MinimapRoot"]
layout_mode = 0
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
color = Color(0, 0, 0, 0)

[node name="SubViewportContainer" type="SubViewportContainer" parent="MinimapAspect/MinimapRoot"]
layout_mode = 0
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
stretch = true

[node name="SubViewport" type="SubViewport" parent="MinimapAspect/MinimapRoot/SubViewportContainer"]
transparent_bg = true
render_target_update_mode = 4

[node name="Camera3D" type="Camera3D" parent="MinimapAspect/MinimapRoot/SubViewportContainer/SubViewport"]
transform = Transform3D(1, 0, 0, 0, 0.42288542, 0.9061832, 0, -0.9061832, 0.42288542, 0, 900, 420)
cull_mask = 2
projection = 1
size = 1000.0
near = 1.0
far = 6000.0
